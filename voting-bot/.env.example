# Twitch bot credentials
BOT_USER_ID=            # User ID of your bot account
OAUTH_TOKEN=            # OAuth access token with scopes: user:bot, user:read:chat, user:write:chat
REFRESH_TOKEN=          # Refresh token issued alongside OAUTH_TOKEN (required for auto-renewal)
CLIENT_ID=              # Your app's Client ID from dev.twitch.tv
CLIENT_SECRET=          # Your app's Client Secret from dev.twitch.tv (required for auto-renewal)

# The channel the bot will join (the streamer's channel)
BROADCASTER_USER_ID=    # User ID of the channel to join

# HTTP bridge server (Roblox polls this)
BRIDGE_PORT=3000            # Port the HTTP server listens on
BRIDGE_SECRET=              # Shared secret — send as X-Bridge-Secret header from Roblox. Required unless BRIDGE_AUTH_DISABLED=true.
# BRIDGE_AUTH_DISABLED=true # Dev-only escape: skips the X-Bridge-Secret check AND binds the bridge to 127.0.0.1. Never set this in production.

# Vote configuration
MIN_VOTE=1
MAX_VOTE=5

# Logging
LOG_LEVEL=info  # debug | info | warn | error
