# Twitch bot credentials
BOT_USER_ID=            # User ID of your bot account
OAUTH_TOKEN=            # OAuth token with scopes: user:bot, user:read:chat, user:write:chat
CLIENT_ID=              # Your app's Client ID from dev.twitch.tv

# The channel the bot will join (the streamer's channel)
BROADCASTER_USER_ID=    # User ID of the channel to join

# HTTP bridge server (Roblox polls this)
BRIDGE_PORT=3000        # Port the HTTP server listens on
BRIDGE_SECRET=          # Shared secret — send as X-Bridge-Secret header from Roblox

# Vote configuration
MIN_VOTE=1
MAX_VOTE=5

# Logging
LOG_LEVEL=info  # debug | info | warn | error
